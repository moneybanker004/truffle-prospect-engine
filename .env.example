# Google Places API (New) - required for location count, ratings, reviews
# Get one at https://console.cloud.google.com/apis/credentials after enabling "Places API (New)"
GOOGLE_PLACES_API_KEY=

# NewsAPI.org - optional, used for expansion/press signal
# Free "Developer" key at https://newsapi.org/register (dev/testing use only, 100 req/day, 1-month lookback)
# If left blank, the expansion signal falls back to "data unavailable" / manual CSV input
NEWSAPI_KEY=
